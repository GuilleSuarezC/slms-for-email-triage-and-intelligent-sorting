# ============================================================================
#  Example environment file. Copy to `.env` and fill in as needed.
#  DO NOT commit a real `.env` (it is git-ignored). No secret is required to
#  run the offline parts of the pipeline; the variables below are optional.
# ============================================================================

# --- Kaggle (only for Track A: the real spam/ham dataset via kagglehub) -------
# Create a token at https://www.kaggle.com/settings -> "Create New API Token".
# Leave empty if you are not running the binary spam/ham track.
KAGGLE_USERNAME=
KAGGLE_KEY=

# --- LM Studio local server (only for corpus generation and zero/few-shot SLM)-
# The scripts talk to a locally running LM Studio server (OpenAI-compatible).
# This is NOT a cloud API and needs no real key; the client uses a placeholder.
LM_STUDIO_BASE_URL=http://localhost:1234/v1
